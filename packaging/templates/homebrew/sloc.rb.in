class Sloc < Formula
  desc "Fast source-lines-of-code counter with separate code and test totals"
  homepage "https://github.com/@REPO@"
  url "https://github.com/@REPO@/releases/download/v@VERSION@/sloc-@VERSION@-source.tar.gz"
  sha256 "@SHA256@"
  license "MIT"
  head "https://github.com/@REPO@.git", branch: "main"

  depends_on "zig" => :build

  def install
    system "zig", "build", "-Doptimize=ReleaseFast", "-Dversion=#{version}", "--prefix", prefix
  end

  test do
    (testpath/"src").mkpath
    (testpath/"src/main.zig").write("const std = @import(\"std\");\n")
    assert_match "TOTAL", shell_output("#{bin}/sloc --summary")
  end
end
